# Xyfos.com - Astro static site
# Canonical: https://xyfos.com

RewriteEngine On

# 1) Force HTTPS (behind proxies/load balancers too)
RewriteCond %{HTTPS} !=on [OR]
RewriteCond %{HTTP:X-Forwarded-Proto} !https
RewriteRule ^ https://%{HTTP_HOST}%{REQUEST_URI} [R=301,L]

# 2) Redirect www -> non-www
RewriteCond %{HTTP_HOST} ^www\.xyfos\.com$ [NC]
RewriteRule ^ https://xyfos.com%{REQUEST_URI} [R=301,L]

# 3) Do not rewrite existing files/directories
RewriteCond %{REQUEST_FILENAME} -f [OR]
RewriteCond %{REQUEST_FILENAME} -d
RewriteRule ^ - [L]

# 4) Astro "pretty URLs": map /path -> /path.html when exists
RewriteCond %{REQUEST_FILENAME}.html -f
RewriteRule ^(.+?)/?$ $1.html [L]

# 5) Fallback to index.html (for sections like /blog/ or /projects/)
DirectoryIndex index.html index.php

<IfModule mod_expires.c>
  ExpiresActive On

  # HTML: revalidate often
  ExpiresByType text/html "access plus 10 minutes"

  # CSS/JS: cache longer
  ExpiresByType text/css "access plus 7 days"
  ExpiresByType application/javascript "access plus 7 days"
  ExpiresByType text/javascript "access plus 7 days"

  # Images/SVG/Icons/Fonts
  ExpiresByType image/svg+xml "access plus 30 days"
  ExpiresByType image/png "access plus 30 days"
  ExpiresByType image/jpeg "access plus 30 days"
  ExpiresByType image/webp "access plus 30 days"
  ExpiresByType image/x-icon "access plus 30 days"
  ExpiresByType font/woff2 "access plus 365 days"
</IfModule>

<IfModule mod_headers.c>
  # Security-ish defaults for a static site
  Header always set X-Content-Type-Options "nosniff"
  Header always set Referrer-Policy "strict-origin-when-cross-origin"
</IfModule>