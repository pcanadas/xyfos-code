---
const nav = [
  { href: "/projects", label: "Projects" },
  { href: "/blog", label: "Blog" },
  { href: "/changelog", label: "Changelog" },
  { href: "/roadmap", label: "Roadmap" },
  { href: "/rss.xml", label: "RSS" },
];
---
<header class="border-b border-slate-200 bg-white">
  <div class="mx-auto flex max-w-5xl items-center justify-between gap-4 px-4 py-4">
    <a href="/" class="flex items-center gap-3">
      <img
        src="/brand/logo-mark.svg"
        alt="Xyfos"
        width="28"
        height="28"
        class="h-7 w-7"
        loading="eager"
        decoding="async"
      />
      <img src="/brand/logo-wordmark.svg" alt="Xyfos Code" height="32" class="h-8 w-auto" />
      <span class="hidden items-center rounded-full border border-brand-200 bg-brand-50 px-2 py-0.5 text-xs font-medium text-slate-700 sm:inline-flex">
        Xyfos Sales
      </span>
    </a>

    <nav class="hidden items-center gap-4 text-sm md:flex">
      {nav.map((item) => (
        <a class="text-slate-600 hover:text-slate-900" href={item.href}>
          {item.label}
        </a>
      ))}
      <a
        class="rounded-md bg-slate-900 px-3 py-1.5 text-white hover:bg-slate-800"
        href="https://app.xyfos.com"
        target="_blank"
        rel="noopener noreferrer"
      >
        Sign in
      </a>
    </nav>

    <div class="md:hidden">
      <a
        class="rounded-md bg-slate-900 px-3 py-1.5 text-sm text-white hover:bg-slate-800"
        href="https://app.xyfos.com"
        target="_blank"
        rel="noopener noreferrer"
      >
        Sign in
      </a>
    </div>
  </div>
</header>