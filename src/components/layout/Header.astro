---
const nav = [
  { href: "/", label: "Home" },
  { href: "/projects", label: "Projects" },
  { href: "/blog", label: "Blog" },
  { href: "/changelog", label: "Changelog" },
  { href: "/roadmap", label: "Roadmap" },
];
---
<header class="border-b border-slate-200">
  <div class="mx-auto flex max-w-5xl items-center justify-between px-4 py-4">
    <a href="/" class="font-semibold tracking-tight">Xyfos Code</a>
    <nav class="flex gap-4 text-sm">
      {nav.map((item) => (
        <a class="text-slate-600 hover:text-slate-900" href={item.href}>{item.label}</a>
      ))}
      <a class="rounded-md bg-slate-900 px-3 py-1.5 text-white hover:bg-slate-800" href="https://app.xyfos.com">
        Sign in
      </a>
    </nav>
  </div>
</header>