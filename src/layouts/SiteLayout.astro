---
import "../styles/global.css";
import Header from "../components/layout/Header.astro";
import Footer from "../components/layout/Footer.astro";
import { getAlternatePath } from "../i18n/utils";
import type { Lang } from "../i18n/utils";

const { title = "Xyfos Code", description = "Build, ship, iterate.", canonical } = Astro.props;
const url = canonical ?? Astro.url.href;
const lang = (Astro.currentLocale ?? "en") as Lang;
const altLang: Lang = lang === "en" ? "es" : "en";
const altPath = getAlternatePath(Astro.url.pathname, lang, altLang);
const baseOrigin = Astro.site?.origin ?? "https://xyfos.com";
---
<!doctype html>
<html lang={lang}>
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={url} />
    <link rel="alternate" hreflang={lang} href={url} />
    <link rel="alternate" hreflang={altLang} href={`${baseOrigin}${altPath}`} />
    <link rel="alternate" hreflang="x-default" href={`${baseOrigin}/`} />
  </head>
  <body class="min-h-screen bg-white text-slate-900">
    <Header />
    <main class="mx-auto w-full max-w-5xl px-4 py-10">
      <slot />
    </main>
    <Footer />
  </body>
</html>