---
import SiteLayout from "../layouts/SiteLayout.astro";
---
<SiteLayout title="Xyfos Code" description="Landing + blog + changelog + roadmap">
  <h1 class="text-4xl font-semibold tracking-tight">Xyfos Code</h1>
  <p class="mt-4 text-lg text-slate-700">
    Building focused SaaS products. First: <span class="font-medium">Xyfos Sales</span>.
  </p>

  <div class="mt-8 flex flex-wrap gap-3">
    <a class="rounded-md bg-slate-900 px-4 py-2 text-white hover:bg-slate-800" href="/projects">View projects</a>
    <a class="rounded-md border border-slate-300 px-4 py-2 hover:bg-slate-50" href="/roadmap">Roadmap</a>
  </div>
</SiteLayout>