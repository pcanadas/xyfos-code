---
import SiteLayout from "../layouts/SiteLayout.astro";
import { getCollection } from "astro:content";

const posts = (await getCollection("blog"))
  .filter((p) => !p.data.draft)
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, 3);

const changelog = (await getCollection("changelog"))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, 3);
---

<SiteLayout
  title="Xyfos Code"
  description="Sales software built to close, not to manage."
>
  <!-- Hero -->
  <section class="relative overflow-hidden rounded-2xl border border-slate-200 bg-white">
    <div class="absolute inset-0">
      <!-- subtle brand glow -->
      <div class="absolute -left-24 -top-24 h-72 w-72 rounded-full bg-brand-200/50 blur-3xl"></div>
      <div class="absolute -right-24 -bottom-24 h-72 w-72 rounded-full bg-brand-300/40 blur-3xl"></div>
    </div>

    <div class="relative p-8 sm:p-12">
      <div class="inline-flex items-center gap-2 rounded-full border border-slate-200 bg-white px-3 py-1 text-xs text-slate-700">
        <span class="h-2 w-2 rounded-full bg-brand-500"></span>
        Xyfos Code · Building QuoteDesk
      </div>

      <h1 class="mt-6 text-4xl font-semibold tracking-tight sm:text-5xl">
        Sales software built to close,
        <span class="underline decoration-brand-500/70 decoration-4 underline-offset-4">
          not to manage
        </span>.
      </h1>

      <p class="mt-5 max-w-2xl text-lg text-slate-700">
        QuoteDesk is an offer-centric system designed around the moments that matter:
        quoting, follow-ups, and decisions. Less admin. More clarity. More wins.
      </p>

      <div class="mt-8 flex flex-wrap gap-3">
        <a
          class="rounded-md bg-slate-900 px-5 py-2.5 text-sm font-medium text-white hover:bg-slate-800"
          href="https://app.xyfos.com"
          target="_blank"
          rel="noopener noreferrer"
        >
          Sign in
        </a>
        <a
          class="rounded-md border border-slate-300 px-5 py-2.5 text-sm font-medium hover:bg-slate-50"
          href="/projects/quote-desk/"
        >
          See QuoteDesk →
        </a>
        <a
          class="rounded-md border border-slate-300 px-5 py-2.5 text-sm font-medium hover:bg-slate-50"
          href="/roadmap"
        >
          Roadmap
        </a>
      </div>

      <div class="mt-10 grid gap-3 sm:grid-cols-3">
        <div class="rounded-xl border border-slate-200 bg-white p-4">
          <div class="text-sm font-semibold">Offer-centric</div>
          <div class="mt-1 text-sm text-slate-600">
            Built around quotes/offers and decision flow.
          </div>
        </div>
        <div class="rounded-xl border border-slate-200 bg-white p-4">
          <div class="text-sm font-semibold">Fast follow-ups</div>
          <div class="mt-1 text-sm text-slate-600">
            Less CRM busywork, more next steps.
          </div>
        </div>
        <div class="rounded-xl border border-slate-200 bg-white p-4">
          <div class="text-sm font-semibold">Clarity</div>
          <div class="mt-1 text-sm text-slate-600">
            See what’s blocking a deal in seconds.
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- Social proof / principles -->
  <section class="mt-12 grid gap-4 md:grid-cols-2">
    <div class="rounded-2xl border border-slate-200 p-6">
      <h2 class="text-xl font-semibold">What I build</h2>
      <p class="mt-2 text-slate-700">
        Practical sales software for small teams that need momentum, not complexity.
      </p>

      <ul class="mt-5 space-y-3 text-sm text-slate-700">
        <li class="flex gap-3">
          <span class="mt-1 h-2 w-2 shrink-0 rounded-full bg-brand-500"></span>
          <span><span class="font-medium">Workflows</span> that match real sales cycles.</span>
        </li>
        <li class="flex gap-3">
          <span class="mt-1 h-2 w-2 shrink-0 rounded-full bg-brand-500"></span>
          <span><span class="font-medium">Speed</span>: fewer clicks, cleaner screens.</span>
        </li>
        <li class="flex gap-3">
          <span class="mt-1 h-2 w-2 shrink-0 rounded-full bg-brand-500"></span>
          <span><span class="font-medium">Signal over noise</span>: focus on next actions.</span>
        </li>
      </ul>
    </div>

    <div class="rounded-2xl border border-slate-200 p-6">
      <h2 class="text-xl font-semibold">Now building</h2>

      <div class="mt-4 rounded-xl border border-brand-200 bg-brand-50 p-5">
        <div class="flex items-center justify-between gap-3">
          <div>
            <div class="text-sm font-semibold">QuoteDesk</div>
            <div class="mt-1 text-sm text-slate-700">
              Offer-centric CRM to help teams close deals faster.
            </div>
          </div>
          <span class="rounded-full bg-white px-3 py-1 text-xs font-medium text-slate-700 ring-1 ring-brand-200">
            alpha
          </span>
        </div>

        <div class="mt-4 flex flex-wrap gap-3">
          <a
            class="rounded-md bg-slate-900 px-4 py-2 text-sm text-white hover:bg-slate-800"
            href="https://app.xyfos.com"
            target="_blank"
            rel="noopener noreferrer"
          >
            Open app
          </a>
          <a
            class="rounded-md border border-slate-300 bg-white px-4 py-2 text-sm hover:bg-slate-50"
            href="/projects/quote-desk/"
          >
            Product page →
          </a>
        </div>
      </div>

      <p class="mt-4 text-sm text-slate-600">
        Transparent progress in <a class="underline" href="/roadmap">Roadmap</a> and <a class="underline" href="/changelog">Changelog</a>.
      </p>
    </div>
  </section>

  <!-- Latest updates -->
  <section class="mt-12 grid gap-6 md:grid-cols-2">
    <div class="rounded-2xl border border-slate-200 p-6">
      <div class="flex items-baseline justify-between gap-3">
        <h2 class="text-xl font-semibold">Latest writing</h2>
        <a class="text-sm text-slate-600 hover:text-slate-900" href="/blog">All posts →</a>
      </div>

      <ul class="mt-5 space-y-4">
        {posts.map((p) => (
          <li>
            <a class="font-medium underline decoration-brand-500/50 underline-offset-4" href={`/blog/${p.slug}/`}>
              {p.data.title}
            </a>
            <div class="mt-1 text-sm text-slate-600">
              {p.data.date.toISOString().slice(0, 10)}
              {p.data.description ? ` · ${p.data.description}` : ""}
            </div>
          </li>
        ))}
        {posts.length === 0 && <li class="text-sm text-slate-600">No posts yet.</li>}
      </ul>
    </div>

    <div class="rounded-2xl border border-slate-200 p-6">
      <div class="flex items-baseline justify-between gap-3">
        <h2 class="text-xl font-semibold">Latest releases</h2>
        <a class="text-sm text-slate-600 hover:text-slate-900" href="/changelog">Changelog →</a>
      </div>

      <ul class="mt-5 space-y-4">
        {changelog.map((e) => (
          <li>
            <a class="font-medium underline decoration-brand-500/50 underline-offset-4" href={`/changelog/${e.slug}/`}>
              {e.data.version} — {e.data.title}
            </a>
            <div class="mt-1 text-sm text-slate-600">
              {e.data.date.toISOString().slice(0, 10)}
            </div>
          </li>
        ))}
        {changelog.length === 0 && <li class="text-sm text-slate-600">No releases yet.</li>}
      </ul>
    </div>
  </section>

  <!-- CTA -->
  <section class="mt-12 rounded-2xl border border-slate-200 bg-slate-900 p-8 text-white">
    <div class="flex flex-col items-start justify-between gap-6 md:flex-row md:items-center">
      <div>
        <h2 class="text-2xl font-semibold">Ready to focus on closing?</h2>
        <p class="mt-2 text-white/80">
          Sign in to QuoteDesk and get back to the deals that matter.
        </p>
      </div>

      <div class="flex flex-wrap gap-3">
        <a
          class="rounded-md bg-white px-5 py-2.5 text-sm font-medium text-slate-900 hover:bg-brand-50"
          href="https://app.xyfos.com"
          target="_blank"
          rel="noopener noreferrer"
        >
          Sign in
        </a>
        <a
          class="rounded-md border border-white/20 px-5 py-2.5 text-sm font-medium hover:bg-white/10"
          href="/roadmap"
        >
          View roadmap
        </a>
      </div>
    </div>
  </section>
</SiteLayout>