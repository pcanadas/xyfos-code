---
import SiteLayout from "../layouts/SiteLayout.astro";
import { useTranslations, getLocalePath } from "../i18n/utils";
import type { Lang } from "../i18n/utils";

const lang = (Astro.currentLocale ?? "en") as Lang;
const t = useTranslations(lang);
---
<SiteLayout title="404 · Xyfos Code" description={t("404.desc")}>
  <div class="py-10">
    <h1 class="text-4xl font-semibold tracking-tight">404</h1>
    <p class="mt-3 text-lg text-slate-700">
      {t("404.desc")}
    </p>

    <div class="mt-8 flex flex-wrap gap-3">
      <a class="rounded-md bg-slate-900 px-4 py-2 text-white hover:bg-slate-800" href={getLocalePath(lang, "/")}>
        {t("404.gohome")}
      </a>
      <a class="rounded-md border border-slate-300 px-4 py-2 hover:bg-slate-50" href={getLocalePath(lang, "/projects")}>
        {t("nav.projects")}
      </a>
      <a class="rounded-md border border-slate-300 px-4 py-2 hover:bg-slate-50" href={getLocalePath(lang, "/blog")}>
        {t("nav.blog")}
      </a>
    </div>

    <div class="mt-10 rounded-xl border border-slate-200 bg-slate-50 p-5 text-sm text-slate-700">
      <p class="font-medium text-slate-900">{t("404.tip")}</p>
      <p class="mt-1">{t("404.tiptext")}</p>
    </div>
  </div>
</SiteLayout>
