---
import SiteLayout from "../layouts/SiteLayout.astro";
---
<SiteLayout title="404 · Xyfos Code" description="Page not found">
  <div class="py-10">
    <h1 class="text-4xl font-semibold tracking-tight">404</h1>
    <p class="mt-3 text-lg text-slate-700">
      This page doesn’t exist (or it moved).
    </p>

    <div class="mt-8 flex flex-wrap gap-3">
      <a class="rounded-md bg-slate-900 px-4 py-2 text-white hover:bg-slate-800" href="/">
        Go home
      </a>
      <a class="rounded-md border border-slate-300 px-4 py-2 hover:bg-slate-50" href="/projects">
        Projects
      </a>
      <a class="rounded-md border border-slate-300 px-4 py-2 hover:bg-slate-50" href="/blog">
        Blog
      </a>
    </div>

    <div class="mt-10 rounded-xl border border-slate-200 bg-slate-50 p-5 text-sm text-slate-700">
      <p class="font-medium text-slate-900">Tip</p>
      <p class="mt-1">
        If you followed a link here from the site, tell me and I’ll fix it.
      </p>
    </div>
  </div>
</SiteLayout>