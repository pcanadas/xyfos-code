---
import SiteLayout from "../../layouts/SiteLayout.astro";
import { getCollection } from "astro:content";

export async function getStaticPaths() {
  const items = await getCollection("changelog");
  return items.map((e) => ({ params: { slug: e.slug }, props: { entry: e } }));
}

const { entry } = Astro.props;
const { Content } = await entry.render();
---
<SiteLayout title={`${entry.data.title} · Changelog · Xyfos Code`} description={`Release ${entry.data.version}`}>
  <h1 class="text-3xl font-semibold">{entry.data.title}</h1>
  <p class="mt-2 text-slate-700">
    <span class="font-medium">{entry.data.version}</span> ·{" "}
    {entry.data.date.toISOString().slice(0, 10)}
  </p>

  <article class="prose prose-slate mt-8 max-w-none">
    <Content />
  </article>
</SiteLayout>