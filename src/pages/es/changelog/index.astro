---
import SiteLayout from "../../../layouts/SiteLayout.astro";
import { getCollection } from "astro:content";
import { useTranslations, getLocalePath } from "../../../i18n/utils";
import type { Lang } from "../../../i18n/utils";

const lang = (Astro.currentLocale ?? "es") as Lang;
const t = useTranslations(lang);
const changelogPath = getLocalePath(lang, "/changelog");

const entries = (await getCollection("changelog")).sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf()
);
---
<SiteLayout title={`${t("changelog.title")} · Xyfos Code`} description={t("changelog.desc")}>
  <h1 class="text-3xl font-semibold">{t("changelog.title")}</h1>
  <p class="mt-2 text-slate-700">{t("changelog.desc")}</p>

  <div class="mt-8 space-y-6">
    {entries.map((e) => (
      <div class="relative rounded-xl border border-slate-200 p-5">
        <div class="flex flex-wrap items-center justify-between gap-3">
          <div>
            <a class="text-lg font-semibold underline" href={`${changelogPath}/${e.slug}/`}>
              {e.data.title}
            </a>
            <div class="mt-1 text-sm text-slate-600">
              <span class="font-medium">{e.data.version}</span> ·{" "}
              {e.data.date.toISOString().slice(0, 10)}
            </div>
          </div>
          <a
            class="text-sm text-slate-600 hover:text-slate-900"
            href={`${changelogPath}/${e.slug}/`}
          >
            {t("common.details")}
          </a>
        </div>
      </div>
    ))}
  </div>
</SiteLayout>
