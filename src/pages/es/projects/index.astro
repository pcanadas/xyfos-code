---
import SiteLayout from "../../../layouts/SiteLayout.astro";
import { getCollection } from "astro:content";
import { useTranslations, getLocalePath } from "../../../i18n/utils";
import type { Lang } from "../../../i18n/utils";

const lang = (Astro.currentLocale ?? "es") as Lang;
const t = useTranslations(lang);
const projectsPath = getLocalePath(lang, "/projects");

const projects = (await getCollection("projects")).sort((a, b) =>
  a.data.title.localeCompare(b.data.title)
);
---
<SiteLayout title={`${t("projects.title")} · Xyfos Code`} description={t("projects.desc")}>
  <h1 class="text-3xl font-semibold">{t("projects.title")}</h1>
  <p class="mt-2 text-slate-700">{t("projects.desc")}</p>

  <div class="mt-8 grid gap-4 sm:grid-cols-2">
    {projects.map((p) => (
      <a
        href={`${projectsPath}/${p.slug}/`}
        class="group rounded-xl border border-slate-200 p-5 hover:border-slate-300 hover:bg-slate-50"
      >
        <div class="flex items-start justify-between gap-4">
          <div>
            <div class="text-lg font-semibold text-slate-900 group-hover:underline">
              {p.data.title}
            </div>
            <div class="mt-1 text-sm text-slate-600">{p.data.description}</div>
          </div>
          <span class="shrink-0 rounded-full border border-slate-200 bg-white px-2.5 py-1 text-xs text-slate-700">
            {p.data.status}
          </span>
        </div>
      </a>
    ))}
  </div>
</SiteLayout>
