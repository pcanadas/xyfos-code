---
import SiteLayout from "../../../layouts/SiteLayout.astro";
import { getCollection } from "astro:content";
import { useTranslations, getLocalePath } from "../../../i18n/utils";
import type { Lang } from "../../../i18n/utils";

const lang = (Astro.currentLocale ?? "es") as Lang;
const t = useTranslations(lang);
const blogPath = getLocalePath(lang, "/blog");

const posts = (await getCollection("blog"))
  .filter((p) => !p.data.draft)
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf());
---
<SiteLayout title={`${t("blog.title")} · Xyfos Code`}>
  <h1 class="text-3xl font-semibold">{t("blog.title")}</h1>
  <ul class="mt-6 space-y-3">
    {posts.map((p) => (
      <li>
        <a class="text-slate-900 underline" href={`${blogPath}/${p.slug}/`}>{p.data.title}</a>
        <div class="text-sm text-slate-600">{p.data.date.toISOString().slice(0,10)}</div>
      </li>
    ))}
    {posts.length === 0 && <li class="text-sm text-slate-600">{t("common.noposts")}</li>}
  </ul>
</SiteLayout>
