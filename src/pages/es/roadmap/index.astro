---
import SiteLayout from "../../../layouts/SiteLayout.astro";
import { getCollection } from "astro:content";
import { useTranslations, getLocalePath } from "../../../i18n/utils";
import type { Lang } from "../../../i18n/utils";

const lang = (Astro.currentLocale ?? "es") as Lang;
const t = useTranslations(lang);
const roadmapPath = getLocalePath(lang, "/roadmap");

const items = (await getCollection("roadmap")).sort(
  (a, b) => b.data.date.valueOf() - a.data.date.valueOf()
);

const planned = items.filter((i) => i.data.status === "planned");
const inProgress = items.filter((i) => i.data.status === "in-progress");
const done = items.filter((i) => i.data.status === "done");

const sections = [
  { title: t("roadmap.inprogress"), items: inProgress },
  { title: t("roadmap.planned"), items: planned },
  { title: t("roadmap.done"), items: done },
];
---
<SiteLayout title={`${t("roadmap.title")} · Xyfos Code`} description={t("roadmap.desc")}>
  <h1 class="text-3xl font-semibold">{t("roadmap.title")}</h1>
  <p class="mt-2 text-slate-700">{t("roadmap.desc")}</p>

  <div class="mt-8 grid gap-8 md:grid-cols-3">
    {sections.map((s) => (
      <section>
        <h2 class="text-base font-semibold text-slate-900">{s.title}</h2>
        <ul class="mt-4 space-y-3">
          {s.items.map((i) => (
            <li class="rounded-xl border border-slate-200 p-4 hover:bg-slate-50">
              <a class="font-medium underline" href={`${roadmapPath}/${i.slug}/`}>{i.data.title}</a>
              <div class="mt-1 text-sm text-slate-600">
                {i.data.date.toISOString().slice(0, 10)}
              </div>
            </li>
          ))}
          {s.items.length === 0 && (
            <li class="text-sm text-slate-500">{t("common.noitems")}</li>
          )}
        </ul>
      </section>
    ))}
  </div>
</SiteLayout>
