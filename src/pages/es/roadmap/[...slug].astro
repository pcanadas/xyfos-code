---
import SiteLayout from "../../../layouts/SiteLayout.astro";
import { getCollection } from "astro:content";

export async function getStaticPaths() {
  const items = await getCollection("roadmap");
  return items.map((r) => ({ params: { slug: r.slug }, props: { item: r } }));
}

const { item } = Astro.props;
const { Content } = await item.render();
---
<SiteLayout title={`${item.data.title} · Roadmap · Xyfos Code`}>
  <div class="flex flex-wrap items-center justify-between gap-3">
    <div>
      <h1 class="text-3xl font-semibold">{item.data.title}</h1>
      <p class="mt-2 text-slate-700">{item.data.date.toISOString().slice(0, 10)}</p>
    </div>

    <span class="rounded-full border border-slate-200 bg-white px-3 py-1 text-sm text-slate-700">
      {item.data.status}
    </span>
  </div>

  <article class="prose prose-slate mt-8 max-w-none">
    <Content />
  </article>
</SiteLayout>
