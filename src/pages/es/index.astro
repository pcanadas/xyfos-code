---
import SiteLayout from "../../layouts/SiteLayout.astro";
import { getCollection } from "astro:content";
import { useTranslations, getLocalePath } from "../../i18n/utils";
import type { Lang } from "../../i18n/utils";

const lang = (Astro.currentLocale ?? "es") as Lang;
const t = useTranslations(lang);

const blogPath = getLocalePath(lang, "/blog");
const projectsPath = getLocalePath(lang, "/projects");
const roadmapPath = getLocalePath(lang, "/roadmap");
const changelogPath = getLocalePath(lang, "/changelog");

const posts = (await getCollection("blog"))
  .filter((p) => !p.data.draft)
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, 3);

const changelog = (await getCollection("changelog"))
  .sort((a, b) => b.data.date.valueOf() - a.data.date.valueOf())
  .slice(0, 3);
---

<SiteLayout
  title="Xyfos Code"
  description={t("home.desc")}
>
  <!-- Hero -->
  <section class="relative overflow-hidden rounded-2xl border border-slate-200 bg-white">
    <div class="absolute inset-0">
      <div class="absolute -left-24 -top-24 h-72 w-72 rounded-full bg-brand-200/50 blur-3xl"></div>
      <div class="absolute -right-24 -bottom-24 h-72 w-72 rounded-full bg-brand-300/40 blur-3xl"></div>
    </div>

    <div class="relative p-8 sm:p-12">
      <div class="inline-flex items-center gap-2 rounded-full border border-slate-200 bg-white px-3 py-1 text-xs text-slate-700">
        <span class="h-2 w-2 rounded-full bg-brand-500"></span>
        {t("home.badge")}
      </div>

      <h1 class="mt-6 text-4xl font-semibold tracking-tight sm:text-5xl">
        {t("home.h1a")}
        <span class="underline decoration-brand-500/70 decoration-4 underline-offset-4">
          {t("home.h1b")}
        </span>.
      </h1>

      <p class="mt-5 max-w-2xl text-lg text-slate-700">
        {t("home.desc")}
      </p>

      <div class="mt-8 flex flex-wrap gap-3">
        <a
          class="rounded-md bg-slate-900 px-5 py-2.5 text-sm font-medium text-white hover:bg-slate-800"
          href="https://app.xyfos.com"
          target="_blank"
          rel="noopener noreferrer"
        >
          {t("nav.signin")}
        </a>
        <a
          class="rounded-md border border-slate-300 px-5 py-2.5 text-sm font-medium hover:bg-slate-50"
          href={`${projectsPath}/xyfos-sales/`}
        >
          {t("home.seeproduct")}
        </a>
        <a
          class="rounded-md border border-slate-300 px-5 py-2.5 text-sm font-medium hover:bg-slate-50"
          href={roadmapPath}
        >
          {t("nav.roadmap")}
        </a>
      </div>

      <div class="mt-10 grid gap-3 sm:grid-cols-3">
        <div class="rounded-xl border border-slate-200 bg-white p-4">
          <div class="text-sm font-semibold">{t("home.feat1.t")}</div>
          <div class="mt-1 text-sm text-slate-600">{t("home.feat1.d")}</div>
        </div>
        <div class="rounded-xl border border-slate-200 bg-white p-4">
          <div class="text-sm font-semibold">{t("home.feat2.t")}</div>
          <div class="mt-1 text-sm text-slate-600">{t("home.feat2.d")}</div>
        </div>
        <div class="rounded-xl border border-slate-200 bg-white p-4">
          <div class="text-sm font-semibold">{t("home.feat3.t")}</div>
          <div class="mt-1 text-sm text-slate-600">{t("home.feat3.d")}</div>
        </div>
      </div>
    </div>
  </section>

  <!-- Principios -->
  <section class="mt-12 grid gap-4 md:grid-cols-2">
    <div class="rounded-2xl border border-slate-200 p-6">
      <h2 class="text-xl font-semibold">{t("home.build.title")}</h2>
      <p class="mt-2 text-slate-700">{t("home.build.desc")}</p>

      <ul class="mt-5 space-y-3 text-sm text-slate-700">
        <li class="flex gap-3">
          <span class="mt-1 h-2 w-2 shrink-0 rounded-full bg-brand-500"></span>
          <span><span class="font-medium">{t("home.build.i1b")}</span>{t("home.build.i1r")}</span>
        </li>
        <li class="flex gap-3">
          <span class="mt-1 h-2 w-2 shrink-0 rounded-full bg-brand-500"></span>
          <span><span class="font-medium">{t("home.build.i2b")}</span>{t("home.build.i2r")}</span>
        </li>
        <li class="flex gap-3">
          <span class="mt-1 h-2 w-2 shrink-0 rounded-full bg-brand-500"></span>
          <span><span class="font-medium">{t("home.build.i3b")}</span>{t("home.build.i3r")}</span>
        </li>
      </ul>
    </div>

    <div class="rounded-2xl border border-slate-200 p-6">
      <h2 class="text-xl font-semibold">{t("home.now.title")}</h2>

      <div class="mt-4 rounded-xl border border-brand-200 bg-brand-50 p-5">
        <div class="flex items-center justify-between gap-3">
          <div>
            <div class="text-sm font-semibold">Xyfos Sales</div>
            <div class="mt-1 text-sm text-slate-700">
              {t("home.now.proddesc")}
            </div>
          </div>
          <span class="rounded-full bg-white px-3 py-1 text-xs font-medium text-slate-700 ring-1 ring-brand-200">
            {t("home.now.badge")}
          </span>
        </div>

        <div class="mt-4 flex flex-wrap gap-3">
          <a
            class="rounded-md bg-slate-900 px-4 py-2 text-sm text-white hover:bg-slate-800"
            href="https://app.xyfos.com"
            target="_blank"
            rel="noopener noreferrer"
          >
            {t("common.openapp")}
          </a>
          <a
            class="rounded-md border border-slate-300 bg-white px-4 py-2 text-sm hover:bg-slate-50"
            href={`${projectsPath}/xyfos-sales/`}
          >
            {t("home.now.productpage")}
          </a>
        </div>
      </div>

      <p class="mt-4 text-sm text-slate-600">
        {t("home.now.progress1")} <a class="underline" href={roadmapPath}>Roadmap</a> {t("home.now.progress2")} <a class="underline" href={changelogPath}>Changelog</a>.
      </p>
    </div>
  </section>

  <!-- Últimas actualizaciones -->
  <section class="mt-12 grid gap-6 md:grid-cols-2">
    <div class="rounded-2xl border border-slate-200 p-6">
      <div class="flex items-baseline justify-between gap-3">
        <h2 class="text-xl font-semibold">{t("home.writing.title")}</h2>
        <a class="text-sm text-slate-600 hover:text-slate-900" href={blogPath}>{t("home.writing.all")}</a>
      </div>

      <ul class="mt-5 space-y-4">
        {posts.map((p) => (
          <li>
            <a class="font-medium underline decoration-brand-500/50 underline-offset-4" href={`${blogPath}/${p.slug}/`}>
              {p.data.title}
            </a>
            <div class="mt-1 text-sm text-slate-600">
              {p.data.date.toISOString().slice(0, 10)}
              {p.data.description ? ` · ${p.data.description}` : ""}
            </div>
          </li>
        ))}
        {posts.length === 0 && <li class="text-sm text-slate-600">{t("common.noposts")}</li>}
      </ul>
    </div>

    <div class="rounded-2xl border border-slate-200 p-6">
      <div class="flex items-baseline justify-between gap-3">
        <h2 class="text-xl font-semibold">{t("home.releases.title")}</h2>
        <a class="text-sm text-slate-600 hover:text-slate-900" href={changelogPath}>{t("home.releases.all")}</a>
      </div>

      <ul class="mt-5 space-y-4">
        {changelog.map((e) => (
          <li>
            <a class="font-medium underline decoration-brand-500/50 underline-offset-4" href={`${changelogPath}/${e.slug}/`}>
              {e.data.version} — {e.data.title}
            </a>
            <div class="mt-1 text-sm text-slate-600">
              {e.data.date.toISOString().slice(0, 10)}
            </div>
          </li>
        ))}
        {changelog.length === 0 && <li class="text-sm text-slate-600">{t("common.noreleases")}</li>}
      </ul>
    </div>
  </section>

  <!-- CTA -->
  <section class="mt-12 rounded-2xl border border-slate-200 bg-slate-900 p-8 text-white">
    <div class="flex flex-col items-start justify-between gap-6 md:flex-row md:items-center">
      <div>
        <h2 class="text-2xl font-semibold">{t("home.cta.title")}</h2>
        <p class="mt-2 text-white/80">
          {t("home.cta.desc")}
        </p>
      </div>

      <div class="flex flex-wrap gap-3">
        <a
          class="rounded-md bg-white px-5 py-2.5 text-sm font-medium text-slate-900 hover:bg-brand-50"
          href="https://app.xyfos.com"
          target="_blank"
          rel="noopener noreferrer"
        >
          {t("nav.signin")}
        </a>
        <a
          class="rounded-md border border-white/20 px-5 py-2.5 text-sm font-medium hover:bg-white/10"
          href={roadmapPath}
        >
          {t("home.cta.viewroadmap")}
        </a>
      </div>
    </div>
  </section>
</SiteLayout>
